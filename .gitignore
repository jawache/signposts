# dependencies
node_modules/

# website build output + cache (site/ is a standalone Astro project)
site/dist/
site/.astro/

# local working-docs journal — scratch, never committed (see .work/README.md).
# No trailing slash: in a worktree .work is a SYMLINK to the main checkout's journal.
.work

# per-worktree dev port, written by the wt pre-start hook (.config/wt.toml)
.wt-port

# engine event log + report cards + refresh base snapshots — local telemetry,
# never committed (per-session JSONL under .signposts/log/; see docs/08-wiring).
.signposts/

# local-only agent settings (per-machine permission grants etc.)
.claude/settings.local.json

# editor / OS
.vscode/
.DS_Store
signposts.code-workspace
