---
// Signposts.astro — the live listing of THIS repo's own signposts, generated at build time from
// the root signposts.yml. Every bundle → its title, summary, and its `signposts:` list (each a
// typed sign or rule with a one-line description). Reading the real config means the page can
// never drift from what the project actually ships.
import fs from 'node:fs';
import { fileURLToPath } from 'node:url';
import { parse as parseYaml } from 'yaml';

const root = fileURLToPath(new URL('../../../../', import.meta.url));
let doc: any = {};
for (const name of ['signposts.yml', 'signposts.yaml']) {
  try { doc = parseYaml(fs.readFileSync(root + name, 'utf8')) || {}; break; } catch { /* try next */ }
}
const RESERVED = new Set(['project', 'config', 'signs', 'rules', 'settings', 'advisory', 'packs', 'install', 'bundles']);
const bundles = Object.entries(doc).filter(([k, v]: [string, any]) => !RESERVED.has(k) && v && typeof v === 'object' && !Array.isArray(v)) as [string, any][];

// The lifecycle moment(s) shown per signpost — its explicit `at`, or the type's default.
const moment = (e: any) => (Array.isArray(e.at) ? e.at.join(' · ') : (e.at || (e.type === 'sign' ? 'touch' : 'write · commit')));
---
<div class="sp-list">
  {bundles.map(([name, b]) => (
    <section class="sp-bundle">
      <h3 id={`bundle-${name}`}>{b.title || name}</h3>
      {b.summary && <p class="sp-summary">{b.summary}</p>}
      <table>
        <thead><tr><th>type</th><th>id</th><th>moment</th><th>what it does</th></tr></thead>
        <tbody>
          {(b.signposts || []).map((e: any) => (
            <tr>
              <td><span class={`sp-chip sp-${e.type}`}>{e.type}</span></td>
              <td><code>{e.id}</code>{e.use && <span class="sp-use"> · {e.use}</span>}</td>
              <td class="sp-moment">{moment(e)}</td>
              <td>{e.description || '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ))}
</div>

<style>
  .sp-bundle { margin: 1.6rem 0 2rem; }
  .sp-summary { color: var(--mut, #6b726a); margin: .2rem 0 .7rem; font-size: .95rem; }
  .sp-chip { font: 700 .62rem "Overpass", system-ui, sans-serif; text-transform: uppercase; letter-spacing: .04em; padding: .1rem .45rem; border-radius: 999px; }
  .sp-chip.sp-sign { background: #eaf2ff; color: #2a6fb0; }
  .sp-chip.sp-rule { background: #fdeee2; color: #c2410c; }
  .sp-use { color: var(--mut, #6b726a); font-family: "Overpass Mono", monospace; font-size: .8em; }
  .sp-moment { white-space: nowrap; font-family: "Overpass Mono", monospace; font-size: .82em; }
  .sp-list table { font-size: .92rem; }
  .sp-list td, .sp-list th { vertical-align: top; }
</style>
